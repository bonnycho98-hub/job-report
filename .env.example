# ===== GitHub Pages 설정 =====
GITHUB_USERNAME=bonnycho98-hub
GITHUB_REPO_NAME=job-report

# ===== 텔레그램 봇 설정 =====
# 1. 텔레그램에서 @BotFather 에게 /newbot 명령어로 봇 생성
# 2. 받은 토큰을 아래에 입력
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# 3. 봇에게 /start 메시지를 보낸 후 아래 명령어로 자동 탐색:
#    python scripts/notify_telegram.py --setup
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===== (선택) 카카오 API 설정 =====
# KAKAO_REST_API_KEY=
# KAKAO_JS_KEY=
# KAKAO_REDIRECT_URI=http://localhost:9999/callback
# KAKAO_ACCESS_TOKEN=
# KAKAO_REFRESH_TOKEN=
